-- MACRO GUI (clean version)
local enabled = false
local running = false
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

local function macroLoop()
	if running then return end
	running = true

	task.spawn(function()
		while running do
			if not enabled then
				task.wait(0.2)
				continue
			end

			local char = player.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")

			if not char or not hum then
				task.wait(0.2)
				continue
			end

			-- TOOL ACTION
			local tool = getTool()
			if tool then
				hum:EquipTool(tool)
			end

			task.wait(0.15)

			-- EMOTE
			pcall(function()
				playEmote()
			end)

			task.wait(0.5)

			-- UNEQUIP
			if hum then
				hum:UnequipTools()
			end

			task.wait(0.4)
		end
	end)
end

-- SETTINGS
local EMOTE_ID = 15610015346
local EMOTE_NAME = "Yungblud Happier Jump"

local enabled = false
local faceConn = nil

-- get any tool in backpack
local function getTool()
	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return nil end

	for _, v in pairs(backpack:GetChildren()) do
		if v:IsA("Tool") then
			-- must have Handle (real weapon/tools usually do)
			local hasHandle = v:FindFirstChild("Handle")

			-- must NOT be your resolver tool
			if hasHandle and v.Name ~= "Resolver" then
				return v
			end
		end
	end

	return nil
end

-- play emote (fixes “only works once” issue)
local function playEmote()
local char = player.Character
if not char then return end

local hum = char:FindFirstChildOfClass("Humanoid")  
if not hum then return end  

if hum.RigType ~= Enum.HumanoidRigType.R15 then return end  

local desc = hum:FindFirstChildOfClass("HumanoidDescription")  
if not desc then  
	desc = Instance.new("HumanoidDescription")  
	desc.Parent = hum  
end  

pcall(function()  
	desc:AddEmote(EMOTE_NAME, EMOTE_ID)  
end)  

task.wait(0.1)  

pcall(function()  
	hum:PlayEmote(EMOTE_NAME)  
end)

end

-- equip + unequip tool
local function toolCycle()
local char = player.Character
if not char then return end

local hum = char:FindFirstChildOfClass("Humanoid")  
if not hum then return end  

local tool = getTool()  
if not tool then return end  

hum:EquipTool(tool)  
task.wait(0.15)  
hum:UnequipTools()

end

-- face forward loop
local lastUpdate = 0

local function faceForward()
local char = player.Character
if not char then return end

local hrp = char:FindFirstChild("HumanoidRootPart")
local cam = workspace.CurrentCamera
if not hrp or not cam then return end

if time() - lastUpdate < 0.03 then return end -- smoother than 0.08
lastUpdate = time()

local look = cam.CFrame.LookVector
local flat = Vector3.new(look.X, 0, look.Z)

if flat.Magnitude > 0 then
flat = flat.Unit
hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + flat)
end

end

