-- AUTO STOP MACRO WHEN TOOL EQUIPPED (REAL FIX)
local function hookToolDetect()

	local function stopMacro()
		enabled = false

		if faceConn then
			faceConn:Disconnect()
			faceConn = nil
		end

		if button then
			button.Text = "VASCAL M OFF"
		end
	end

	local function watch()
		task.spawn(function()
			while player.Character do
				task.wait(0.15)

				local char = player.Character
				local backpack = player:FindFirstChild("Backpack")

				if not char or not backpack then
					continue
				end

				-- check character (equipped tool)
				for _, v in pairs(char:GetChildren()) do
					if v:IsA("Tool") then
						stopMacro()
						return
					end
				end

				-- check backpack (just in case instant swap games)
				for _, v in pairs(backpack:GetChildren()) do
					if v:IsA("Tool") and v.Parent == char then
						stopMacro()
						return
					end
				end
			end
		end)
	end

	player.CharacterAdded:Connect(function()
		task.wait(1)
		watch()
	end)

	if player.Character then
		watch()
	end
end

hookToolDetect()

